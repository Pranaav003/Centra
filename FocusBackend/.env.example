# Server Configuration
# Production (e.g. Render): set NODE_ENV=production, FRONTEND_URL to your frontend origin, TRUST_PROXY=true. PORT is set by Render.
PORT=5001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/centra-app

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Stripe Configuration
# Production: use live keys and live price IDs from Stripe Dashboard (Live mode).
# Get your test API key from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Stripe Webhook Secret
# Production: create live webhook pointing at https://<your-backend>/api/subscription/webhook; paste Signing secret here.
# For local development, use Stripe CLI: stripe listen --forward-to localhost:5001/api/subscription/webhook
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Price IDs (must match frontend VITE_STRIPE_PRICE_* for Checkout)
# Production: use live price IDs from Stripe Dashboard → Products (Live).
STRIPE_PRICE_MONTHLY=price_your_monthly_price_id_here
STRIPE_PRICE_ANNUAL=price_your_annual_price_id_here
STRIPE_PRICE_LIFETIME=price_your_lifetime_price_id_here

# Production (e.g. Render): set true so rate limiting and IP detection work behind proxy.
TRUST_PROXY=false

# Optional: AI-powered analytics insights
# When set, "Refresh AI" on Analytics uses OpenAI to generate personalized insights
# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_INSIGHTS_MODEL=gpt-4o-mini

# Account deletion feedback email (default: pranaav.iyer@gmail.com)
# FEEDBACK_TO_EMAIL=pranaav.iyer@gmail.com

# Resend (for sending feedback emails) - get from https://resend.com/api-keys
# Production: set RESEND_API_KEY on Render backend env.
RESEND_API_KEY=re_your_resend_api_key
# Optional: sender address (must be verified in Resend). Default: Centra <onboarding@resend.dev>
# RESEND_FROM=Centra <noreply@yourdomain.com>
