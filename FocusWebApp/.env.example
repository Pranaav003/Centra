# Frontend build-time env (Vite). Production: set these in Render Static Site → Environment before building.
# Never commit real production values; set them only in Render dashboard.

# Backend API base URL (include /api). Production: https://<your-backend>.onrender.com/api
VITE_API_URL=http://localhost:5001/api

# Frontend URL for redirects (no trailing slash). Must match backend FRONTEND_URL in production.
VITE_FRONTEND_URL=http://localhost:3000

# Stripe Price IDs – must match backend STRIPE_PRICE_* for Checkout. Production: use live price IDs.
VITE_STRIPE_PRICE_MONTHLY=price_your_monthly_price_id_here
VITE_STRIPE_PRICE_ANNUAL=price_your_annual_price_id_here
VITE_STRIPE_PRICE_LIFETIME=price_your_lifetime_price_id_here

# Optional: Developer unlock code (header text box). Default in code: centradev
# VITE_DEV_UNLOCK_CODE=centradev
