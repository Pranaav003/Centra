# API Configuration
# Backend API URL
VITE_API_URL=http://localhost:5001/api

# Frontend URL (for redirects)
VITE_FRONTEND_URL=http://localhost:3000

# Stripe Price IDs
# These must match the Price IDs in your backend .env file
# Get from Stripe Dashboard: https://dashboard.stripe.com/test/products
VITE_STRIPE_PRICE_MONTHLY=price_your_monthly_price_id_here
VITE_STRIPE_PRICE_ANNUAL=price_your_annual_price_id_here
VITE_STRIPE_PRICE_LIFETIME=price_your_lifetime_price_id_here

# Optional: Developer unlock code (header text box). Default: centradev
# VITE_DEV_UNLOCK_CODE=centradev
